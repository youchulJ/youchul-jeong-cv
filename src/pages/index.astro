			<div class="main-wrapper">
				<section class="section summary-section">
					<h2 class="section-title">
						<span class="icon-holder">👋</span>
						Profile
					</h2>
					<div class="summary">
						<p>Youchul Jeong is a Ph.D. candidate in the Department of Marine Science at the University of the Aegean (<a href="https://mrsg.aegean.gr/" target="_blank" rel="noopener noreferrer">Marine Remote Sensing Group - MRSG</a>), specializing in advanced geospatial technologies for marine environmental challenges. His research develops multi-scale detection frameworks for floating marine debris, integrating multi-sensor satellite data with high-resolution UAV imagery to provide actionable insights into plastic pollution. Currently based in Lesbos, Greece, he aims to leverage remote sensing and image processing to develop scalable solutions for ocean conservation, bridging the gap between orbital observations and practical environmental management.</p>
					</div><!--//summary-->
				</section><!--//section-->
				
				<section class="section experiences-section">
					<div class="section-header" onclick="toggleMainSection('research')">
						<h2 class="section-title">
							<span class="icon-holder">🔬</span>
							Research Experience
						</h2>
						<span class="section-arrow">▼</span>
					</div>
					<div id="research">
						{cv.experience.map(item => (
							<div class="experience">
								<div class="item">
									<h3 class="title">{item.position}</h3>
									<h4 class="meta">{item.institution}</h4>
									<div class="time">{item.period}</div>
									<p class="description">{item.description}</p>
								</div><!--//item-->
							</div><!--//experience-->
						))}
					</div>
				</section><!--//section-->
				
				<section class="section experiences-section">
					<div class="section-header" onclick="toggleMainSection('teaching')">
						<h2 class="section-title">
							<span class="icon-holder">🎓</span>
							Teaching Experience
						</h2>
						<span class="section-arrow">▼</span>
					</div>
					<div id="teaching">
						{cv.teaching.map(item => (
							<div class="teaching">
								<div class="item">
									<h3 class="title">{item.position}</h3>
									<h4 class="meta">{item.institution}</h4>
									<div class="time">{item.period}</div>
									<p class="description">{item.description}</p>
								</div><!--//item-->
							</div><!--//teaching-->
						))}
					</div>
				</section><!--//section-->
				
				<section class="section experiences-section">
					<div class="section-header" onclick="toggleMainSection('publications')">
						<h2 class="section-title">
							<span class="icon-holder">📄</span>
							Publications
						</h2>
						<span class="section-arrow">▼</span>
					</div>
					<div id="publications">
						{groupedPublications.map(yearGroup => (
							<div class="year-group">
								<h3 class="year-title">{yearGroup.year}</h3>
								{yearGroup.publications.map(pub => (
									<div class="experience">
										<div class="item">
											<h3 class="title">
												<a href={pub.link} target="_blank">{pub.title}</a>
											</h3>
											<h4 class="meta">{pub.journal}</h4>
											<div class="time">{pub.month} {pub.year}</div>
										</div><!--//item-->
									</div><!--//experience-->
								))}
							</div><!--//year-group-->
						))}
					</div>
				</section><!--//section-->
			</div><!--//main-wrapper-->
		</div>
		
		<script>
			function toggleMainSection(sectionId) {
				console.log('Toggle called for:', sectionId);
				const content = document.getElementById(sectionId);
				const header = content.previousElementSibling;
				const arrow = header.querySelector('.section-arrow');
				
				console.log('Elements found:', !!content, !!header, !!arrow);
				console.log('Current display:', content.style.display);
				
				if (content.style.display === 'none' || content.style.display === '') {
					// 펼치기
					content.style.display = 'block';
					arrow.textContent = '▼';
					header.classList.remove('collapsed');
					console.log('Expanded to block');
				} else {
					// 접기
					content.style.display = 'none';
					arrow.textContent = '▶';
					header.classList.add('collapsed');
					console.log('Collapsed to none');
				}
			}
			
			// 이벤트 리스너로 onclick 대체 (모든 섹션)
			document.addEventListener('DOMContentLoaded', function() {
				console.log('DOM loaded, setting up event listeners...');
				
				const sections = ['research', 'teaching', 'publications'];
				sections.forEach(sectionId => {
					const header = document.querySelector(`[onclick="toggleMainSection('${sectionId}')"]`);
					if (header) {
						header.addEventListener('click', function(e) {
							e.preventDefault();
							console.log('Click event triggered for:', sectionId);
							toggleMainSection(sectionId);
						});
						console.log('Event listener added for:', sectionId);
					} else {
						console.error('Header not found for:', sectionId);
					}
				});
			});
		</script>
	</body>
</html>
